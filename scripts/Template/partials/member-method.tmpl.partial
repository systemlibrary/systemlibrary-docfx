
<h3 id="{{id}}" data-uid="{{uid}}">
    ???
    @%@{{syntax.content.0.value}}@%@
    @!@isStatic@!@
    {{^syntax.return.type}}
    <span class="member-returntype">void</span>
    {{/syntax.return.type}}

    {{#syntax.return}}
    <span class="member-returntype">
    {{syntax.return.type.name.0.value}}
    </span>
    {{/syntax.return}}

    <span class="member-name">
    {{name.0.value}}
    </span>
    @!@isGeneric@!@
    @!@isProperty@!@
    ???
</h3>

