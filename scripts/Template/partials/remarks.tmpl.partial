<div class="remarks-wrapper">
  <button class="btn btn-sm btn-outline-secondary remarks-toggle" onclick="toggleSection(this)"> ▼ Remarks</button>
  <div class="markdown level0 remarks-content" style="display:none">
    <span class="remarks-close" onclick="toggleSection(this.closest('.remarks-wrapper').querySelector('.remarks-toggle'))">✕</span>
    {{{remarks}}}
  </div>
</div>

