
<span class="member-line">
    @!@isStatic@!@

  <span class="member-type">
    {{type.name.0.value}}
    {{type.name}}
  </span>

  <span class="member-name">
    {{name.0.value}}
  </span>

  {{#syntax.propertyValue}}
    <span class="member-prop">{ get; set; }</span>
  {{/syntax.propertyValue}}
</span>
