{{>partials/class.header}}

{{#isEnum}}
  <h3 class="class-content-title"><span>enum </span>{{name.0.value}}</h3>
  <span>{</span>
  <div class="class-body">
    {{#children}}
    <dl class="parameters">
    {{#children}}
       {{#summary}}
      <div class="class-enum-key-summary">
        <dd>
          {{{summary}}}
          {{#remarks}}{{{remarks}}}{{/remarks}}
        </dd>
      </div>
      {{/summary}}
      <dt id="{{id}}">&nbsp;&nbsp;{{syntax.content.0.value}}</dt>
    {{/children}}
    </dl>
    {{/children}}
  </div>
  <span>}</span>
{{/isEnum}}

