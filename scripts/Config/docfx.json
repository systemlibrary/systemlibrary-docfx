{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "files": [
            "**/*.csproj"
          ],
          "exclude": [
            "**/.vs/**",
            "**/obj/**",
            "**/bin/**",
            "**/App_Data/**",
            "**/modules/**",
            "**/imports/**",
            "**/node_modules/**",
            "**/dist/**",
            "**/css/**",
            "**/styles/**",
            "**/static/**",
            "**/public/**",
            "**/*Tests.csproj",
            "**/*Benchmarks.csproj",
            "**/*Test.csproj",
            "**/*Benchmark.csproj"
          ]
        }
      ],
      "dest": "docsapi"
    }
  ],
  "build": {
    "content": [
      {
        "src": "@DocumentationRelativePath",
        "files": [
          "**/*.md",
          "**/*.yml"
        ]
      },
      {
        "files": [
          "docsapi/**/*.yml"
        ]
      }
    ],
    "resource": [
      {
        "src": "@DocumentationRelativePath",
        "files": [
          "**/*.html",
          "**/*.png",
          "**/*.svg",
          "**/*.ico",
          "**/*.jpg",
          "**/*.jpeg",
          "**/*.gif",
          "**/*.webp",
          "**/*.avi",
          "**/*.mp4",
          "**/*.zip"
        ]
      }
    ],
    "filterConfig": "docfxfilter.yml",
    "output": "__docfxsite",
    "markdownEngineName": "markdig",
    "template": [
      "default",
      "docfxtemplate"
    ],
    "globalMetadata": {
      "_appLogoPath": "logo.@LogoExtension",
      "_appName": " ",
      "_appTitle": "@SiteTitle",
      "_disableContribution": true,
      "_disableBreadcrumb": true,
      "_disableNavbar": false,
      "_enableSearch": @EnableSearch,
      "_disableAffix": true,
      "_disableToc": false,
      "hideInheritedMembers": true,
      "__summaryAsToggle": @SummaryAsToggle,
      "pdf": false
    },
    "disableGitFeatures": @DisableGitFeatures
  }
}